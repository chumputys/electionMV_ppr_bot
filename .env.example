# Data file location
DATA_FILE_PATH=./data/data.csv

# Delay between each person (in seconds)
DELAY_BETWEEN_PEOPLE=15

# Max retries per person when timeout occurs
MAX_RETRIES_PER_PERSON=1

# Rate limit retry wait times (in minutes)
RATE_LIMIT_WAIT_1ST=2
RATE_LIMIT_WAIT_2ND=5
RATE_LIMIT_WAIT_3RD=10
